// ======= SETTINGS - YEHAN APNI KEY DALO =======
const GROQ_API_KEY =( "gsk_CNmSXJmw06yVTIQG2MikWG)+(dyb3FY4aySCsajAxXkL8NajnC8eeVs"); // groq.com se free le lo
const DAILY_LIMIT = 5;
const MODEL = "llama-3.1-8b-instant"; // sabse tez free model

// ======= LIMIT SYSTEM =======
let usesLeft = localStorage.getItem('ai_uses');
let lastDate = localStorage.getItem('ai_date');
let today = new Date().toDateString();

// Naya din = reset
if(lastDate!== today) {
  usesLeft = DAILY_LIMIT;
  localStorage.setItem('ai_date', today);
  localStorage.setItem('ai_uses', DAILY_LIMIT);
}

usesLeft = parseInt(usesLeft) || DAILY_LIMIT;
updateUI();

// UI Update karega limit + button
function updateUI() {
  let limitEl = document.getElementById('limit');
  let sendBtn = document.getElementById('sendBtn');
  let adBtn = document.getElementById('watchAdBtn');

  if(limitEl) limitEl.innerText = usesLeft;

  if(usesLeft <= 0) {
    if(sendBtn) sendBtn.disabled = true;
    if(adBtn) adBtn.style.display = 'block';
  } else {
    if(sendBtn) sendBtn.disabled = false;
    if(adBtn) adBtn.style.display = 'none';
  }
}

// ======= MSG BHEJNE KA SYSTEM =======
async function sendMsg() {
  let input = document.getElementById('userInput');
  let msg = input.value.trim();

  if(!msg) return alert('Kuch likho bhai 😅');
  if(usesLeft <= 0) return alert('Limit khatam! Ad dekho 5 use pao');

  // User ka msg dikhao
  addMessage(msg, 'user');
  input.value = '';

  // Limit kam karo
  usesLeft--;
  localStorage.setItem('ai_uses', usesLeft);
  updateUI();

  // Loading msg
  addMessage('Soch raha hun... 🤔', 'bot', true);

  try {
    // GROQ API CALL - AI KA DIMAAG YAHAN HAI
    let response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + GROQ_API_KEY
      },
      body: JSON.stringify({
        model: MODEL,
        messages: [
          {role: 'system', content: 'Tum Rehan ke AI dost ho. Urdu me short aur helpful jawab do.'},
          {role: 'user', content: msg}
        ],
        max_tokens: 500,
        temperature: 0.7
      })
    });

    let data = await response.json();

    if(data.error) {
      throw new Error(data.error.message);
    }

    let reply = data.choices[0].message.content;

    // Loading hata ke reply dikhao
    removeLoading();
    addMessage(reply, 'bot');

  } catch(error) {
    removeLoading();
    addMessage('Arre network error aa gaya bhai. WiFi check karo 🔄', 'bot');
    console.log(error);

    // Agar error aaye to limit wapis kar do
    usesLeft++;
    localStorage.setItem('ai_uses', usesLeft);
    updateUI();
  }
}

// ======= MSG SCREEN PE DIKHANA =======
function addMessage(text, sender, isLoading = false) {
  let chatBox = document.getElementById('chatBox');
  if(!chatBox) return;

  let div = document.createElement('div');
  div.className = 'msg ' + sender;
  if(isLoading) div.id = 'loadingMsg';
  div.innerText = text;

  chatBox.appendChild(div);
  chatBox.scrollTop = chatBox.scrollHeight;
}

function removeLoading() {
  let loading = document.getElementById('loadingMsg');
  if(loading) loading.remove();
}

// ======= AD DEKH KE RESET SYSTEM =======
function watchAd() {
  alert('📺 Ab AdSense ka video ad chalega\nAd khatam hote hi 5 use wapis mil jayenge!');

  // YAHAN ADSENSE REWARDED AD KA CODE LAGEGA
  // Test ke liye direct reset kar rahe hain
  setTimeout(() => {
    usesLeft = DAILY_LIMIT;
    localStorage.setItem('ai_uses', DAILY_LIMIT);
    updateUI();
    alert('Shabash! 🎉 5 free use mil gaye');
    addMessage('Ad dekhne ka shukriya! Ab 5 sawal aur pooch sakte ho 😎', 'bot');
  }, 2000);
}

// ======= ENTER KEY SE SEND =======
document.addEventListener('DOMContentLoaded', function() {
  let input = document.getElementById('userInput');
  if(input) {
    input.addEventListener('keypress', function(e) {
      if(e.key === 'Enter') sendMsg();
    });
  }
});
