let GROQ_KEY = localStorage.getItem('groq_key');
const DAILY_LIMIT = 5;

// ===== LIMIT SYSTEM =====
let usesLeft = localStorage.getItem('ai_uses');
let lastDate = localStorage.getItem('ai_date');
let today = new Date().toDateString();

if(lastDate!== today) {
  usesLeft = DAILY_LIMIT;
  localStorage.setItem('ai_date', today);
  localStorage.setItem('ai_uses', DAILY_LIMIT);
}
usesLeft = parseInt(usesLeft) || DAILY_LIMIT;
updateUI();

// ===== KEY KA BUTTON =====
function setKey() {
  let key = prompt("🔑 Groq API Key dalo bhai:\ngroq.com se free le lo");
  if(key && key.startsWith('gsk_')) {
    localStorage.setItem('groq_key', key);
    GROQ_KEY = key;
    alert('Key save ho gai! Ab AI chalay ga ✅');
    document.getElementById('keyBtn').style.display = 'none';
  } else {
    alert('Ghalat key hai. gsk_ se start hoti hai');
  }
}

// Page load pe check karo key hai ya nahi
window.onload = function() {
  if(!GROQ_KEY) {
    document.getElementById('keyBtn').style.display = 'block';
    document.getElementById('sendBtn').disabled = true;
  } else {
    document.getElementById('keyBtn').style.display = 'none';
  }
  updateUI();
}

function updateUI() {
  let limitEl = document.getElementById('limit');
  let sendBtn = document.getElementById('sendBtn');
  let adBtn = document.getElementById('watchAdBtn');
  if(limitEl) limitEl.innerText = usesLeft;
  if(usesLeft <= 0) {
    if(sendBtn) sendBtn.disabled = true;
    if(adBtn) adBtn.style.display = 'block';
  } else {
    if(sendBtn) sendBtn.disabled = false;
    if(adBtn) adBtn.style.display = 'none';
  }
}

async function sendMsg() {
  if(!GROQ_KEY) return alert('Pehle Key Set karo button se 🔑');
  
  let input = document.getElementById('userInput');
  let msg = input.value.trim();
  if(!msg) return alert('Kuch likho bhai 😅');
  if(usesLeft <= 0) return alert('Limit khatam! Ad dekho 5 use pao');

  addMessage(msg, 'user');
  input.value = '';
  usesLeft--;
  localStorage.setItem('ai_uses', usesLeft);
  updateUI();
  addMessage('Soch raha hun... 🤔', 'bot', true);

  try {
    let res = await fetch("https://api.groq.com/openai/v1/chat/completions", {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + GROQ_KEY,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: "llama-3.1-8b-instant",
        messages: [
          {role: "system", content: "Tum Rehan ke AI dost ho. Urdu/Roman Urdu me short jawab do."},
          {role: "user", content: msg}
        ]
      })
    });
    let data = await res.json();
    let reply = data.choices[0].message.content;
    removeLoading();
    addMessage(reply, 'bot');
  } catch(e) {
    removeLoading();
    addMessage('Error: Key ghalat hai ya net ka masla 🤔', 'bot');
  }
}

function addMessage(text, sender, loading=false) {
  let box = document.getElementById('chatBox');
  let div = document.createElement('div');
  div.className = 'msg ' + sender;
  if(loading) div.id = 'loadingMsg';
  div.style.cssText = sender==='user'? 'text-align:right; margin:10px 0; background:#667eea; color:white; padding:10px 15px; border-radius:15px 15px 0 15px; display:inline-block; float:right; clear:both' : 'text-align:left; margin:10px 0; background:#f0f0f0; padding:10px 15px; border-radius:15px 15px 15px 0; display:inline-block; float:left; clear:both';
  div.innerText = text;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}
function removeLoading() { document.getElementById('loadingMsg')?.remove(); }
function watchAd() {
  alert('Ad start... 3 sec baad 5 use mil jayenge!');
  setTimeout(() => {
    usesLeft = DAILY_LIMIT;
    localStorage.setItem('ai_uses', DAILY_LIMIT);
    updateUI();
    alert('Mubarak ho! 5 free sawal wapis 🎉');
  }, 3000);
}
